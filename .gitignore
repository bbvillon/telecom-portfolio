# ══════════════════════════════════════════════════════════════════
# ROOT — block everything, whitelist only allowed files & folders
# ══════════════════════════════════════════════════════════════════
/*
!/.gitignore
!/README.md
!/requirements.txt
!/config.py
!/loading.py
!/LICENSE
!/tests/
!/docs/
!/src/

# ══════════════════════════════════════════════════════════════════
# data/ — block all contents
/data/**

# docs/ — block everything except allowed file
/docs/**
!/docs/pipeline_decisions.md

# notebooks/ — block all
/notebooks/**

# output/ — block all
/output/**

# reports/ — block all
/reports/**

# ══════════════════════════════════════════════════════════════════
# src/ — allow only specific files
!/src/
!/src/fault_ticket/
!/src/visualization/
!/src/utils/

# ignore everything inside src subfolders
/src/fault_ticket/*
/src/visualization/*
/src/utils/*

# allow only the portfolio modules
!src/__init__.py
!src/fault_ticket/pipeline.py
!src/fault_ticket/metrics.py
!src/fault_ticket/analysis.py
!src/fault_ticket/__init__.py
!src/visualization/common_plots.py
!src/visualization/fault_ticket_plots.py
!src/visualization/__init__.py
!src/utils/__init__.py

# ══════════════════════════════════════════════════════════════════
# tests/ — track everything
!/tests/**

# ══════════════════════════════════════════════════════════════════
# Python
__pycache__/
*.py[cod]
*.pyo
.env
*.egg-info/
dist/
build/
.venv/
venv/

# ══════════════════════════════════════════════════════════════════
# Jupyter
*.ipynb
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ══════════════════════════════════════════════════════════════════
# OS
.DS_Store
Thumbs.db
desktop.ini
