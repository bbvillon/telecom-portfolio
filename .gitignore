# ══════════════════════════════════════════════════════════════════
# ROOT — block everything, whitelist only allowed files & folders
# ══════════════════════════════════════════════════════════════════
/*
!/.gitignore
!/README.md
!/requirements.txt
!/data/
!/docs/
!/notebooks/
!/output/
!/reports/
!/src/
!/tests/
!config.py
!loading.py

# ══════════════════════════════════════════════════════════════════
# data/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/data/**


# ══════════════════════════════════════════════════════════════════
# docs/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/docs/**
!/docs/pipeline_decisions.md

# ══════════════════════════════════════════════════════════════════
# notebooks/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/notebooks/**


# ══════════════════════════════════════════════════════════════════
# output/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/output/**


# ══════════════════════════════════════════════════════════════════
# reports/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/reports/**


# ══════════════════════════════════════════════════════════════════
# src/ 
# ══════════════════════════════════════════════════════════════════
!/src/fault_ticket/
!/src/visualization/
!/src/utils/
/src/*
!src/fault_ticket/pipeline.py
!src/fault_ticket/metrics.py
!src/fault_ticket/analysis.py
!src/fault_ticket/__init__.py
!src/visualization/common_plots.py
!src/visualization/fault_ticket_plots.py
!src/visualization/__init__.py
!src/utils/__init__.py
!src/__init__.py

# ══════════════════════════════════════════════════════════════════
# tests/ 
# ══════════════════════════════════════════════════════════════════
!/tests/**


# ══════════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
.env
*.egg-info/
dist/
build/
.venv/
venv/


# ══════════════════════════════════════════════════════════════════
# Jupyter
# ══════════════════════════════════════════════════════════════════
*.ipynb
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# ══════════════════════════════════════════════════════════════════
# OS
# ══════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini