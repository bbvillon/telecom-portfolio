# ══════════════════════════════════════════════════════════════════
# ROOT — block everything, whitelist only allowed files & folders
# ══════════════════════════════════════════════════════════════════
/*
!/.gitignore
!/README.md
!/requirements.txt
!/data/
!/docs/
!/notebooks/
!/output/
!/reports/
!/src/


# ══════════════════════════════════════════════════════════════════
# data/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/data/**


# ══════════════════════════════════════════════════════════════════
# docs/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/docs/**


# ══════════════════════════════════════════════════════════════════
# notebooks/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/notebooks/**


# ══════════════════════════════════════════════════════════════════
# output/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/output/**


# ══════════════════════════════════════════════════════════════════
# reports/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/reports/**


# ══════════════════════════════════════════════════════════════════
# src/ — empty for now (all contents blocked)
# ══════════════════════════════════════════════════════════════════
/src/**


# ══════════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
.env
*.egg-info/
dist/
build/
.venv/
venv/


# ══════════════════════════════════════════════════════════════════
# Jupyter
# ══════════════════════════════════════════════════════════════════
*.ipynb
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# ══════════════════════════════════════════════════════════════════
# OS
# ══════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini