# ══════════════════════════════════════════════════════════════════
# ROOT — block everything, whitelist only allowed files & folders
# ══════════════════════════════════════════════════════════════════
/*
!/.gitignore
!/README.md
!/requirements.txt
!/config.py
!/loading.py
!/LICENSE
!/notebooks/
!/tests/
!/docs/
!/src/
!/output/
!/reports/

# ══════════════════════════════════════════════════════════════════
# data/ — allow only specific folders and files

# allow the data folder
!/data/

# allow subfolders
!/data/external/
!/data/raw/
!/data/raw/fault_tickets/

# ignore everything inside data subfolders
/data/external/*
!/data/external/site_database_synthetic.csv

/data/raw/fault_tickets/*
!/data/raw/fault_tickets/synthetic_dataset.csv

!/data/.gitkeep
# ══════════════════════════════════════════════════════════════════

# docs/ — allow only specific files
/docs/**
!/docs/data_dictionary.md
!/docs/pipeline_decisions.md

# notebooks/ — allow only specific files
/notebooks/*
!/notebooks/project1_ncr_baseline/
!/notebooks/project2_resolution_paths/
!/notebooks/project3_zone_performance/
!/notebooks/project4_city_intelligence/
!/notebooks/project5_site_risk_profiling/
!/notebooks/project1_ncr_baseline/*.ipynb
!/notebooks/project2_resolution_paths/*.ipynb
!/notebooks/project3_zone_performance/*.ipynb
!/notebooks/project4_city_intelligence/*.ipynb
!/notebooks/project5_site_risk_profiling/*.ipynb
/notebooks/project1_ncr_baseline/00__run_script.ipynb

# output/ — allow only specific files
/output/**
!/output/ncr_summary.csv
!/output/data_validation_report.csv
!/output/resolution_path_analysis.csv
!/output/top_100_sites.csv

# reports/ — allow only specific files
/reports/**
!/reports/figures/
!/reports/figures/project1_ncr/
!/reports/figures/project2_ncr/
!/reports/figures/project3_ncr/
!/reports/figures/project4_ncr/
!/reports/figures/project5_ncr/
!/reports/figures/project1_ncr/**
!/reports/figures/project2_ncr/**
!/reports/figures/project3_ncr/**
!/reports/figures/project4_ncr/**
!/reports/figures/project5_ncr/**


# ══════════════════════════════════════════════════════════════════
# src/ — allow only specific files
!/src/
!/src/fault_ticket/
!/src/visualization/
!/src/utils/

# ignore everything inside src subfolders
/src/fault_ticket/*
/src/visualization/*
/src/utils/*

# allow only the portfolio modules
!/src/__init__.py
!/src/fault_ticket/pipeline.py
!/src/fault_ticket/metrics.py
!/src/fault_ticket/analysis.py
!/src/fault_ticket/__init__.py
!/src/visualization/common_plots.py
!/src/visualization/fault_ticket_plots.py
!/src/visualization/__init__.py
!/src/utils/__init__.py

# ignore the projects folder completely for now
/src/projects/

# ignore the projects folder completely for now
/src/projects/

# ══════════════════════════════════════════════════════════════════
# tests/ — track everything
!/tests/**

# ══════════════════════════════════════════════════════════════════
# Python
__pycache__/
*.py[cod]
*.pyo
.env
*.egg-info/
dist/
build/
.venv/
venv/

# ══════════════════════════════════════════════════════════════════
# Jupyter
*.ipynb
!notebooks/project1_ncr_baseline/*.ipynb
!notebooks/project2_resolution_paths/*.ipynb
!notebooks/project3_zone_performance/*.ipynb
!notebooks/project4_city_intelligence/*.ipynb
!notebooks/project5_site_risk_profiling/*.ipynb
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ══════════════════════════════════════════════════════════════════
# OS
.DS_Store
Thumbs.db
desktop.ini
